# ============================================================
# BL Algo Trading – Environment Variables Template
# Copy this file to .env and fill in the values
# NEVER commit .env to version control
# ============================================================

# ── Required ─────────────────────────────────────────────────
# Anthropic API Key (for Claude LLM view generation)
# Get yours at: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-api03-...

# ── Optional ─────────────────────────────────────────────────
# Finnhub API Key (for live news fetching)
# Without this, the project uses the local news_database.json
# Get yours at: https://finnhub.io/dashboard
FINNHUB_API_KEY=

# ── Settings ─────────────────────────────────────────────────
DEBUG=false
CACHE_DIR=./data
RESULTS_DIR=./results
